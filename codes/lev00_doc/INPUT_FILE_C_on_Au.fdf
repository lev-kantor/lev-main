# Label                                                                                             
SystemName      Au_bulk                                                                             
SystemLabel INPUT_C_on_96at

# Optimisation                                                                                      
MD.TypeOfRun          CG                                                                            
MD.VariableCell       .false.                                                                       
MD.NumCGSteps         60
MD.MaxCGDispl         0.01 Ang                                                                      
MD.MaxForceTol        0.03 eV/Ang                                                                   

# SCF                                                                                               
SolutionMethod diagon
DM.NumberPulay        3                                                                             
DM.MixingWeight       0.05                                                                          
SpinPolarized         false                                                                         

# Basis set                                                                                         
MeshCutoff            200 Ry                                                                        
PAO.EnergyShift       10. meV                                                                       
PAO.BasisSize         DZP                                                                           
NetCharge             0.0                                                                           
kgrid_cutoff          0.0 Ang                                                                       

# Functional                                                                                        
MaxSCFIterations      120                                                                           
DM.Tolerance          1.e-4                                                                         

#############################################################                                       
XC.functional            GGA                                                                        
XC.authors               PBE   #CA, PW92 for LDA,  LYP, PBE                                        
#############################################################                                       

# I/O                                                                                               
#LongOutput            true                                                                          
#UseSaveData           true                                                                          
#DM.UseSaveDM           true                                                                        
#SaveRho               true                                                                         

%block GeometryConstraints
position from          5 to          8
position from         13 to         16
position from         21 to         24
position from         29 to         32
position from         37 to         40
position from         45 to         48
position from         53 to         56
position from         61 to         64
position from         69 to         72
position from         77 to         80
position from         85 to         88
position from         93 to         96
%endblock GeometryConstraints


NumberOfSpecies     5
NumberOfAtoms     109

%block ChemicalSpeciesLabel
    1 79 Au
    2  6  C
    3  7  N
    4  1  H
    5  8  O
%endblock ChemicalSpeciesLabel

